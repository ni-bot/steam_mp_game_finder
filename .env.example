# Required: generate with `openssl rand -base64 32`
AUTH_SECRET=

# Public URL of your deployment (no trailing slash)
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Steam Web API key: https://steamcommunity.com/dev/apikey
STEAM_WEB_API_KEY=

# Optional: Upstash Redis for serverless cache (falls back to in-memory locally)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cache TTL for owned games / app metadata (seconds, default 10800 = 3h)
CACHE_TTL_SECONDS=10800
